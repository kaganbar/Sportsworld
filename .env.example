# Postgres (used by both the db service and the Django backend)
POSTGRES_DB=sportsworld
POSTGRES_USER=sportsworld
POSTGRES_PASSWORD=sportsworld
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (Channels layer for live WebSocket ticking — backend + live_ticker services)
REDIS_HOST=redis
REDIS_PORT=6379

# Claude API (Football Agent — Phase 1)
# AI_AGENT_MODE: "mock" (default when no key is set) returns hardcoded, schema-shaped
# agent responses at no cost — for building/testing UI and data flow. "live" makes a
# real Claude call and requires ANTHROPIC_API_KEY.
AI_AGENT_MODE=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# NestJS backend (backend-nest/) live data source, Phase D
# "scraper" (default) pulls real fixtures/scores from 365scores.com every 45s.
# "simulated" falls back to the old random-walk mock ticker over seeded data
# (no internet access needed). "off" disables both.
LIVE_DATA_SOURCE=scraper

# Frontend (Vite, existing)
VITE_API_URL=http://localhost:8000

# Frontend-next (Next.js, Phase 2 scaffold) — NEXT_PUBLIC_ prefix is Next.js's
# equivalent of Vite's VITE_ prefix for client-exposed env vars.
NEXT_PUBLIC_API_URL=http://localhost:8001
