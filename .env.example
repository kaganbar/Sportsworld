# Postgres (used by both the db service and the Django backend)
POSTGRES_DB=sportsworld
POSTGRES_USER=sportsworld
POSTGRES_PASSWORD=sportsworld
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (Channels layer for live WebSocket ticking — backend + live_ticker services)
REDIS_HOST=redis
REDIS_PORT=6379

# Claude API (Football Agent — Phase 1)
# AI_AGENT_MODE: "mock" (default when no key is set) returns hardcoded, schema-shaped
# agent responses at no cost — for building/testing UI and data flow. "live" makes a
# real Claude call and requires ANTHROPIC_API_KEY.
AI_AGENT_MODE=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# NestJS backend (backend-nest/) live data source, Phase D
# "scraper" (default) pulls real fixtures/scores from 365scores.com every 45s.
# "simulated" falls back to the old random-walk mock ticker over seeded data
# (no internet access needed). "off" disables both.
LIVE_DATA_SOURCE=scraper

# Auth (Phase 4, backend-nest only) — Google OAuth + JWT, NestJS is the
# system of record (see ARCHITECTURE.md's Auth section).
# GOOGLE_CLIENT_ID/SECRET come from a Google Cloud OAuth 2.0 Client ID
# (console.cloud.google.com -> APIs & Services -> Credentials). Configure
# its "Authorized redirect URI" to exactly match GOOGLE_CALLBACK_URL below.
# Left blank, the app still boots (GoogleStrategy degrades to a placeholder
# clientID rather than crashing on startup) but /api/auth/google will fail
# at Google's end until real credentials are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8001/api/auth/google/callback
JWT_ACCESS_SECRET=dev-insecure-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-insecure-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Where /api/auth/google/callback redirects after a successful login.
FRONTEND_URL=http://localhost:3000

# News ingestion (Phase 6) — NewsAPI.org, GET /v2/top-headlines?category=sports.
# Free "Developer" tier key from newsapi.org. Polled hourly (not the ~45s
# cadence the live-scores scraper uses) to stay well within the ~100 req/day
# free quota. Left blank, ingestion just no-ops — News Center stays on its
# placeholder.
NEWS_API_KEY=

# Frontend (Vite, existing)
VITE_API_URL=http://localhost:8000

# Frontend-next (Next.js, Phase 2 scaffold) — NEXT_PUBLIC_ prefix is Next.js's
# equivalent of Vite's VITE_ prefix for client-exposed env vars.
NEXT_PUBLIC_API_URL=http://localhost:8001
