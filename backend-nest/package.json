{
  "name": "sportsworld-backend-nest",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "seed": "ts-node prisma/seed.ts",
    "seed:competitions": "ts-node prisma/seed-competitions.ts",
    "backfill:competitions": "ts-node prisma/backfill-competitions.ts",
    "backfill:hebrew-content": "ts-node prisma/backfill-hebrew-content.ts",
    "enrich:real-players": "ts-node prisma/enrich-real-players.ts",
    "enrich:football-data-squads": "ts-node prisma/enrich-football-data-squads.ts",
    "enrich:balldontlie-rosters": "ts-node prisma/enrich-balldontlie-rosters.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "jest": {
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleFileExtensions": ["js", "json", "ts"],
    "testEnvironment": "node"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-ws": "^10.4.0",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/websockets": "^10.4.0",
    "@prisma/client": "^5.20.0",
    "axios": "^1.7.7",
    "cheerio": "^1.0.0",
    "ioredis": "^5.11.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.22",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/ws": "^8.5.12",
    "jest": "^30.4.2",
    "prisma": "^5.20.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
