generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sport {
  football
  basketball
}

enum GameStatus {
  scheduled
  live
  finished
}

enum InjuryStatus {
  out
  doubtful
  suspended
}

enum Tour {
  atp
  wta
}

enum Confidence {
  low
  medium
  high
}

enum TransferStatus {
  rumor
  official
  completed
  denied
}

model Team {
  id           Int    @id @default(autoincrement())
  sport        Sport  @default(football)
  name         String @unique
  shortName    String
  country      String
  primaryColor String @default("#1E7B34")

  players            Player[]
  homeGames          Game[]               @relation("HomeTeam")
  awayGames          Game[]               @relation("AwayTeam")
  homeResults        MatchResult[]        @relation("HomeResultTeam")
  awayResults        MatchResult[]        @relation("AwayResultTeam")
  injuries           Injury[]
  lineups            Lineup[]
  statisticsAnalyses StatisticsAnalysis[]
  teamCompetitions   TeamCompetition[]
}

// Canonical competition/league (Premier League, NBA, ATP Tour, ...),
// seeded per sport rather than derived — the scraper's own
// `competitionDisplayName` strings are free text with no guaranteed
// taxonomy (e.g. "Champions League" vs "UEFA Champions League"), so a
// real filterable nav needs a stable slug to route/cache on. `aliases`
// is the raw-string match list (exact match, extended over time);
// `slug: "other"` is a reserved per-sport bucket for anything unmatched
// so scraped data is never silently hidden. `sportKey` is a plain string
// (not the `Sport` enum) since tennis has no `Sport` member.
model Competition {
  id       Int      @id @default(autoincrement())
  sportKey String
  // Unique per sport, not globally — "world-cup" is a valid slug for both
  // football and basketball, disambiguated by the sport param on every
  // route/endpoint that consumes it.
  slug     String
  name     String
  nameHe   String
  tier     Int      @default(99)
  aliases  String[]

  games             Game[]
  matchResults      MatchResult[]
  tennisMatches     TennisMatch[]
  teamCompetitions  TeamCompetition[]
  newsStoryClusters NewsStoryCluster[]
  transferStories   TransferStory[]

  @@unique([sportKey, slug])
}

// Derived, not user-facing: a team's competition membership is observed
// from the games it actually plays (populated in normalize.service.ts as
// games are ingested), not configured by hand.
model TeamCompetition {
  id            Int         @id @default(autoincrement())
  team          Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId        Int
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  competitionId Int

  @@unique([teamId, competitionId])
}

model Player {
  id          Int    @id @default(autoincrement())
  team        Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      Int
  name        String
  position    String
  shirtNumber Int
  // Season-stat chips for the player profile screen. Shape depends on
  // team.sport: football -> {goals, assists, rating}, basketball ->
  // {ppg, rpg, apg}. JSON (not dedicated columns) since the two sports need
  // different fields and Player is shared across both — see games app
  // split note at the top of this file.
  seasonStats Json?

  injuries Injury[]
  lineups  Lineup[]

  @@unique([teamId, shirtNumber])
}

model Game {
  id             Int          @id @default(autoincrement())
  sport          Sport        @default(football)
  competition    String
  kickoff        DateTime
  venue          String
  status         GameStatus   @default(scheduled)
  homeTeam       Team         @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  homeTeamId     Int
  awayTeam       Team         @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  awayTeamId     Int
  homeScore      Int?
  awayScore      Int?
  minute         Int? // football's live clock only
  // Per-game team stat breakdown for the match-detail Overview tab's
  // proportion bars, e.g. football {home:{possession,shots,shotsOnTarget,
  // corners}, away:{...}}. Nullable/JSON: only a subset of seeded/scraped
  // games carry it, and the 4-field shape differs per sport.
  stats          Json?
  // Resolved from the raw `competition` string at ingest time (see
  // CompetitionsService.resolveCompetition) — nullable so pre-migration
  // rows and not-yet-backfilled data still work; the raw string column
  // above stays the source of truth for display and the natural key.
  competitionRef Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  competitionId  Int?

  lineups       Lineup[]
  quarterScores QuarterScore[]
  analyses      MatchAnalysis[]
  predictions   PredictionAnalysis[]

  // Doubles as the scraper's natural key for upserts.
  @@unique([sport, competition, kickoff, homeTeamId, awayTeamId])
  @@index([competitionId])
}

model Lineup {
  id         Int     @id @default(autoincrement())
  game       Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId     Int
  team       Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId     Int
  player     Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId   Int
  isStarting Boolean @default(true)
  position   String

  @@unique([gameId, playerId])
}

// A finished historical game — recent-form/H2H are derived by querying this
// (plus finished Games), not a stored join table. Mirrors games.MatchResult.
model MatchResult {
  id             Int          @id @default(autoincrement())
  date           DateTime     @db.Date
  competition    String
  homeTeam       Team         @relation("HomeResultTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  homeTeamId     Int
  awayTeam       Team         @relation("AwayResultTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  awayTeamId     Int
  homeScore      Int
  awayScore      Int
  competitionRef Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  competitionId  Int?

  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([competitionId])
}

model Injury {
  id       Int          @id @default(autoincrement())
  player   Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId Int
  team     Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   Int
  status   InjuryStatus
  reason   String
}

// Basketball-only per-quarter score breakdown — the one genuinely
// sport-specific model, everything else above is shared with football.
model QuarterScore {
  id        Int  @id @default(autoincrement())
  game      Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId    Int
  quarter   Int
  homeScore Int
  awayScore Int

  @@unique([gameId, quarter])
}

model TennisPlayer {
  id            Int    @id @default(autoincrement())
  name          String @unique
  country       String
  tour          Tour
  ranking       Int?
  // Season-stat chips for the player profile screen (World Rank comes from
  // `ranking` above; these two cover Win % / Aces per match).
  winPct        Float?
  acesPerMatch  Float?

  matchesAsP1        TennisMatch[]        @relation("P1")
  matchesAsP2        TennisMatch[]        @relation("P2")
  wonMatches         TennisMatch[]        @relation("Winner")
  statisticsAnalyses StatisticsAnalysis[]
}

model TennisMatch {
  id             Int           @id @default(autoincrement())
  tour           Tour
  tournament     String
  round          String
  venue          String
  startTime      DateTime
  status         GameStatus    @default(scheduled)
  player1        TennisPlayer  @relation("P1", fields: [player1Id], references: [id], onDelete: Cascade)
  player1Id      Int
  player2        TennisPlayer  @relation("P2", fields: [player2Id], references: [id], onDelete: Cascade)
  player2Id      Int
  winner         TennisPlayer? @relation("Winner", fields: [winnerId], references: [id], onDelete: SetNull)
  winnerId       Int?
  competitionRef Competition?  @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  competitionId  Int?
  // Match-detail Overview tab stat rows: {home:{aces,winners,unforcedErrors,
  // doubleFaults}, away:{...}}. Same nullable/JSON pattern as Game.stats.
  stats          Json?

  sets        TennisSet[]
  analyses    MatchAnalysis[]
  predictions PredictionAnalysis[]

  @@unique([tour, tournament, round, startTime, player1Id, player2Id])
  @@index([competitionId])
}

model TennisSet {
  id           Int         @id @default(autoincrement())
  match        TennisMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId      Int
  setNumber    Int
  player1Games Int
  player2Games Int

  @@unique([matchId, setNumber])
}

// Auth (Phase 4) — Google OAuth is the only identity source for now, so
// googleId is required rather than nullable; if a second auth method is
// ever added, that's the point to make it optional and add a discriminator.
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  googleId  String   @unique
  name      String
  avatarUrl String?
  createdAt DateTime @default(now())
}

// Shared by Transfer and News (Phase 5 schema; the agents that populate
// these are Phase 8, not built yet) — a real outlet like "Sky Sports" or a
// named reporter plausibly breaks both transfer rumors and general news, so
// one credibility concept is reused rather than duplicated per domain.
// credibilityScore is 0-100, ranked by the Transfer Agent per the source
// spec's "rank source credibility" requirement — no real sources are seeded
// here, that's a real-world editorial judgment call for whenever Phase 8
// actually needs one, not something to fabricate now.
model ContentSource {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  url              String?
  credibilityScore Int      @default(50)
  createdAt        DateTime @default(now())

  transferReports TransferReport[]
  newsArticles    NewsArticle[]
}

// Canonical grouping a raw TransferReport belongs to — this is what "merge
// duplicate reports" structurally requires: without a grouping concept,
// dedup logic has nothing to attach its result to. estimatedProbability is
// null until an agent actually scores it (Phase 8), not a placeholder guess.
model TransferStory {
  id                   Int            @id @default(autoincrement())
  playerName           String
  fromClub             String?
  toClub               String
  status               TransferStatus @default(rumor)
  estimatedProbability Int?
  // Transfer Agent's (Phase 8) 1-2 sentence synthesis across every report
  // attached to this story. English-only for now — unlike MatchAnalysis,
  // a story is one row shared across all readers rather than duplicated
  // per language, so per-language summaries would need a separate table;
  // not worth it until the Transfer Center frontend actually needs it.
  aiSummary            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  reports      TransferReport[]
  // Best-effort tagging: fromClub/toClub matched against Team.name,
  // resolved to competitions via TeamCompetition (see
  // TransferAgentService.groupUngroupedReports). Deliberately
  // many-to-many, not a single competitionId — a transfer can be
  // relevant to more than one competition (a team's league + cup).
  competitions Competition[]

  @@index([playerName])
}

// One raw report from one source — several of these merge into one
// TransferStory once a dedup pass (Phase 8) identifies them as the same
// rumor. storyId is nullable so a freshly-scraped report can exist before
// it's been matched to (or started) a story.
model TransferReport {
  id                Int            @id @default(autoincrement())
  story             TransferStory? @relation(fields: [storyId], references: [id], onDelete: SetNull)
  storyId           Int?
  source            ContentSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId          Int
  playerName        String
  fromClub          String?
  toClub            String
  status            TransferStatus @default(rumor)
  description       String
  sourceUrl         String         @unique
  // A source's own published probability for this rumor (e.g. Transfermarkt's
  // "user assessment" %), distinct from TransferStory.estimatedProbability
  // which is our own agent's estimate (Phase 8) — kept separate so a real
  // data point isn't conflated with something we haven't computed yet.
  sourceProbability Int?
  reportedAt        DateTime
  createdAt         DateTime       @default(now())

  @@index([storyId])
}

// Canonical grouping for deduped news coverage of the same event — same
// role as TransferStory but for NewsArticle. `sport` is a loose string tag
// rather than a hard FK to the Sport enum (football/basketball only) since
// news can cover tennis, other sports, or nothing sport-specific at all.
model NewsStoryCluster {
  id        Int      @id @default(autoincrement())
  headline  String
  summary   String?
  sport     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles     NewsArticle[]
  // Best-effort tagging: headline/summary text matched against
  // Team.name/shortName, resolved to competitions via TeamCompetition
  // (see NewsAgentService.clusterUnclusteredArticles).
  competitions Competition[]
}

model NewsArticle {
  id          Int               @id @default(autoincrement())
  cluster     NewsStoryCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  clusterId   Int?
  source      ContentSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceId    Int
  title       String
  url         String            @unique
  summary     String?
  publishedAt DateTime
  createdAt   DateTime          @default(now())

  @@index([clusterId])
}

// English -> Hebrew dictionary, sport-agnostic. Falls back to sourceText
// when no entry exists (see TranslationsService).
model NameTranslation {
  id             Int    @id @default(autoincrement())
  sourceText     String @unique
  translatedText String
  category       String @default("")
}

// One model for all three sports' AI analysis, not three Django-style apps —
// they differ only by a nullable column (drawPct vs player1/2WinPct), so a
// single table with nullable FKs/fields avoids triplicating cache logic.
// Exactly one of gameId/tennisMatchId is populated per row.
model MatchAnalysis {
  id            Int          @id @default(autoincrement())
  sport         String // "football" | "basketball" | "tennis"
  game          Game?        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId        Int?
  tennisMatch   TennisMatch? @relation(fields: [tennisMatchId], references: [id], onDelete: Cascade)
  tennisMatchId Int?
  language      String       @default("en")
  summary       String
  keyFactors    String[]
  homeWinPct    Int? // football + basketball
  drawPct       Int? // football only
  awayWinPct    Int? // football + basketball
  player1WinPct Int? // tennis only
  player2WinPct Int? // tennis only
  confidence    Confidence
  model         String
  createdAt     DateTime     @default(now())

  @@unique([gameId, language])
  @@unique([tennisMatchId, language])
}

// Statistics Agent (Phase 8) — a real-data-only narrative digest of one
// team's or player's form, keyed the same dual-nullable way MatchAnalysis
// keys per-game rows (exactly one of teamId/tennisPlayerId populated per
// row). Deliberately no probability fields here — that's Prediction
// Agent's job; this table is form/H2H commentary only.
model StatisticsAnalysis {
  id             Int           @id @default(autoincrement())
  sport          String // "football" | "basketball" | "tennis"
  team           Team?         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId         Int?
  tennisPlayer   TennisPlayer? @relation(fields: [tennisPlayerId], references: [id], onDelete: Cascade)
  tennisPlayerId Int?
  language       String        @default("en")
  summary        String
  keyPoints      String[]
  confidence     Confidence
  model          String
  createdAt      DateTime      @default(now())

  @@unique([teamId, language])
  @@unique([tennisPlayerId, language])
}

// Prediction Agent (Phase 8) — the general cross-sport synthesis tool
// (confirmed scope: it independently re-predicts a matchup from
// Statistics Agent's data, for ANY sport including football/basketball/
// tennis, rather than only covering sports without a dedicated agent).
// Keyed exactly like MatchAnalysis (one of gameId/tennisMatchId per row).
// probabilities is Json because football is 3-way and basketball/tennis
// are 2-way — see prediction-agent.schema.ts for the two Zod shapes that
// get normalized into it.
model PredictionAnalysis {
  id            Int          @id @default(autoincrement())
  sport         String
  game          Game?        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId        Int?
  tennisMatch   TennisMatch? @relation(fields: [tennisMatchId], references: [id], onDelete: Cascade)
  tennisMatchId Int?
  language      String       @default("en")
  prediction    String
  keyFactors    String[]
  probabilities Json
  confidence    Confidence
  model         String
  createdAt     DateTime     @default(now())

  @@unique([gameId, language])
  @@unique([tennisMatchId, language])
}

// Master Agent (Phase 8) — the tool-use-loop synthesis report, cached on a
// hash of the free-text query since (unlike every other agent) its subject
// isn't a game/team/player ID but an arbitrary user question.
model MasterReport {
  id         Int      @id @default(autoincrement())
  queryHash  String   @unique
  queryText  String
  language   String   @default("en")
  reportText String
  model      String
  createdAt  DateTime @default(now())
}
